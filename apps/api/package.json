{
  "name": "@txg/api",
  "version": "0.1.0",
  "private": true,
  "description": "10xGains backend API: Hono app hosted on Azure Functions (Node 24).",
  "main": "dist/main.js",
  "scripts": {
    "dev": "pnpm run start",
    "start": "pnpm build && func start",
    "build": "node esbuild.mjs",
    "build:deploy": "pnpm build && node pack.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" && pnpm typecheck",
    "lint:fix": "eslint --fix \"src/**/*.ts\" && pnpm typecheck",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@azure/functions": "^4.7.0",
    "@marplex/hono-azurefunc-adapter": "^1.0.1",
    "@supabase/supabase-js": "^2.49.4",
    "@txg/shared": "workspace:*",
    "hono": "^4.7.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.2",
    "azure-functions-core-tools": "^4",
    "esbuild": "^0.25.0",
    "eslint": "9",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "^3.2.2"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ]
  }
}
