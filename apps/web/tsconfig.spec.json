{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": [
      "vitest/globals"
    ],
    "target": "es2016",
    "paths": {
      "@features/*": ["./src/app/features/*"],
      "@shared/*": ["./src/app/shared/*"],
      "@txg/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "files": [
    "src/test-setup.ts"
  ]
}
