{
  "name": "@txg/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:development": "ng serve --configuration=development --host 0.0.0.0",
    "start:staging": "ng serve --configuration=staging",
    "start:production": "ng serve --configuration=production",
    "build": "ng build",
    "build:development": "ng build --configuration=development",
    "build:staging": "ng build --configuration=staging",
    "build:production": "ng build --configuration=production",
    "lint": "eslint \"src/**/*.{ts,html}\"",
    "lint:fix": "eslint --fix \"src/**/*.{ts,html}\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@angular/animations": "19.2.7",
    "@angular/cdk": "19.2.9",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/material": "19.2.9",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@angular/service-worker": "^19.2.0",
    "@supabase/supabase-js": "^2.49.4",
    "@tailwindcss/postcss": "^4.1.3",
    "@txg/shared": "workspace:*",
    "postcss": "^8.5.3",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.3",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@analogjs/platform": "^1.15.1",
    "@analogjs/vite-plugin-angular": "^1.15.1",
    "@analogjs/vitest-angular": "^1.17.1",
    "@angular-devkit/build-angular": "^19.2.7",
    "@angular/build": "^19.2.7",
    "@angular/cli": "^19.2.7",
    "@angular/compiler-cli": "^19.2.0",
    "@nx/angular": "^20.7.2",
    "@nx/devkit": "^20.7.2",
    "@nx/vite": "^20.7.2",
    "@vitest/coverage-v8": "^3.2.2",
    "@vitest/ui": "^3.2.2",
    "angular-eslint": "19.3.0",
    "autoprefixer": "^10.4.21",
    "eslint": "8",
    "eslint-import-resolver-typescript": "^4.3.4",
    "eslint-plugin-import": "^2.31.0",
    "jsdom": "^22.0.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "8.27.0",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^4.2.0",
    "vitest": "^3.2.2"
  },
  "lint-staged": {
    "src/**/*.{html,ts}": [
      "eslint --fix"
    ]
  }
}
