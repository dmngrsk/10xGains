{
  "name": "@txg/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run start:development",
    "ng": "ng",
    "start": "ng serve",
    "start:development": "ng serve --configuration=development --host 0.0.0.0",
    "start:staging": "ng serve --configuration=staging",
    "start:production": "ng serve --configuration=production",
    "build": "ng build",
    "build:development": "ng build --configuration=development",
    "build:staging": "ng build --configuration=staging",
    "build:production": "ng build --configuration=production",
    "lint": "eslint \"src/**/*.{ts,html}\"",
    "lint:fix": "eslint --fix \"src/**/*.{ts,html}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/service-worker": "^22.0.0",
    "@supabase/supabase-js": "^2.49.4",
    "@tailwindcss/postcss": "^4.1.3",
    "@txg/shared": "workspace:*",
    "postcss": "^8.5.3",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.3",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.2",
    "@analogjs/vitest-angular": "^2.6.2",
    "@angular-devkit/build-angular": "^22.0.5",
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^9.39.4",
    "@vitest/coverage-v8": "^3.2.2",
    "@vitest/ui": "^3.2.2",
    "angular-eslint": "22.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "9",
    "eslint-import-resolver-typescript": "^4.3.4",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^22.0.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "^6.4.3",
    "vite-tsconfig-paths": "^4.2.0",
    "vitest": "^3.2.2"
  },
  "lint-staged": {
    "src/**/*.{html,ts}": [
      "eslint --fix"
    ]
  }
}
