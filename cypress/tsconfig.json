{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "dom"],
    "sourceMap": true,
    "types": ["cypress", "node"],
    /* Cypress's webpack preprocessor injects the deprecated downlevelIteration
       option; silence the TS 6 deprecation error until Cypress stops doing so. */
    "ignoreDeprecations": "6.0"
  },
  "include": ["**/*.ts"]
}
