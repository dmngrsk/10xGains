{
  "name": "10xGains",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "pnpm --filter @txg/web start",
    "start:dev": "pnpm --filter @txg/web start:dev",
    "start:development": "pnpm --filter @txg/web start:development",
    "start:staging": "pnpm --filter @txg/web start:staging",
    "start:production": "pnpm --filter @txg/web start:production",
    "build": "pnpm --filter @txg/web build",
    "build:development": "pnpm --filter @txg/web build:development",
    "build:staging": "pnpm --filter @txg/web build:staging",
    "build:production": "pnpm --filter @txg/web build:production",
    "lint": "pnpm -r lint && echo \"Running eslint (cypress)...\" && eslint \"cypress/**/*.ts\" && echo \"Running deno lint...\" && deno lint supabase/functions/**/*.ts",
    "lint:fix": "pnpm -r lint:fix && echo \"Running eslint --fix (cypress)...\" && eslint --fix \"cypress/**/*.ts\" && echo \"Running deno lint --fix...\" && deno lint --fix supabase/functions/**/*.ts",
    "test": "pnpm -r test && vitest run",
    "test:coverage": "pnpm -r test:coverage && vitest run --coverage",
    "test:watch": "vitest",
    "e2e": "cypress open",
    "e2e:run": "cypress run",
    "e2e:smoke": "cypress run --env grepTags=@smoke,grepFilterSpecs=true,grepOmitFiltered=true"
  },
  "devDependencies": {
    "@cypress/grep": "^4.1.0",
    "@supabase/supabase-js": "^2.49.4",
    "@types/deno": "^2",
    "@vitest/coverage-v8": "^3.2.2",
    "cypress": "^14.4.1",
    "deno": "^2.3.5",
    "dotenv": "^16.5.0",
    "eslint": "8",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "supabase": "2.30.4",
    "typescript": "~5.7.2",
    "typescript-eslint": "8.27.0",
    "vitest": "^3.2.2"
  },
  "lint-staged": {
    "cypress/**/*.ts": [
      "eslint --fix"
    ],
    "supabase/functions/**/*.ts": [
      "deno lint --fix"
    ]
  },
  "packageManager": "pnpm@11.9.0"
}
